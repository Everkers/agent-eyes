{
  "name": "agent-eyes",
  "version": "0.1.0",
  "description": "Give LLMs and coding agents eyes into your running app — logs, network, UI, errors, performance, and React components.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agent-eyes": "./dist/mcp/cli.cjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "workspaces": [
    "examples/*",
    "docs"
  ],
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "llm",
    "agent",
    "devtools",
    "debugging",
    "react",
    "nextjs",
    "vite",
    "observability",
    "ai",
    "coding-assistant"
  ],
  "author": "",
  "license": "Apache-2.0",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@types/ws": "^8.18.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "html2canvas": "^1.4.1",
    "ws": "^8.19.0"
  }
}
